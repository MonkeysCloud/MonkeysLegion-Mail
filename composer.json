{
    "name": "monkeyscloud/monkeyslegion-mail",
    "description": "Mail integration package for the MonkeysLegion framework.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "mailer",
        "email",
        "smtp",
        "log",
        "psr",
        "monkeyslegion",
        "monkeyscloud",
        "notifications",
        "markdown",
        "php-mailer",
        "mailing",
        "email-driver",
        "mail-integration"
    ],
    "autoload": {
        "psr-4": {
            "MonkeysLegion\\Mail\\": "src/",
            "MonkeysLegion\\Mailer\\Tests\\": "tests/"
        },
        "files": [
            "src/Support/helpers.php"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.4",
        "league/commonmark": "^2.7",
        "monkeyscloud/monkeyslegion-cli": "^1.0 || ^2.0",
        "monkeyscloud/monkeyslegion-core": "^1.0 || ^2.0",
        "monkeyscloud/monkeyslegion-di": "^1.0 || ^2.0",
        "monkeyscloud/monkeyslegion-logger": "^1.0 || ^2.0",
        "monkeyscloud/monkeyslegion-queue": "^1.1 || ^2.0",
        "monkeyscloud/monkeyslegion-template": "^1.0 || ^2.0",
        "psr/event-dispatcher": "^1.0",
        "psr/log": "^3.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse src --level=max",
        "cs-fix": "php-cs-fixer fix src",
        "ci": [
        "@analyse",
        "@test"
        ]
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94",
        "monkeyscloud/monkeyslegion-mlc": "^3.1",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^12.2"
    },
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "8.4.1"
        },
        "optimize-autoloader": true,
        "allow-plugins": {
            "infection/extension-installer": true
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    }
}
